# ============================================
# LOCAL-DEV-SLM Environment Configuration
# ============================================

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# Database
DATABASE_URL=sqlite:///data/database.db

# Auth
SESSION_TIMEOUT_HOURS=24

# AI Defaults
DEFAULT_WRITER_MODEL=llama3.2:3b
DEFAULT_REVIEWER_MODEL=phi3:mini
MAX_RETRY_ATTEMPTS=3
MAX_LOOP_ITERATIONS=10
MAX_PROMPT_LENGTH=10000
MAX_CODE_LENGTH=50000

# Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
SQL_DEBUG=false